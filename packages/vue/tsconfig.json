{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "dist",
    "declaration": true,
    "emitDeclarationOnly": false,
    "paths": {
      "@danran_chen/custom-ui-vue": ["src/index.ts"],
      "@danran_chen/custom-ui-vue/*": ["src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue"],
  "exclude": [
    "dist",
    "node_modules",
    "src/**/__tests__/**",
    "src/**/*.test.ts",
    "src/components/smoke-test/**"
  ]
}
